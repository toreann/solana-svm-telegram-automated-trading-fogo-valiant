NODE_ENV=development
LOG_LEVEL=info
DATABASE_PATH=./data/tradebot.db

TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=replace_me
TELEGRAM_SESSION_FILE=./secrets/telegram.session
TELEGRAM_SIGNAL_CHAT_ID=-1001234567890
TELEGRAM_ALLOWED_SENDER_IDS=
TELEGRAM_ALLOWED_SENDER_LABELS=@MacacoClub_bot,Mr. Robot

CONTROL_BOT_TOKEN=replace_me
CONTROL_OWNER_CHAT_ID=123456789
CONTROL_OWNER_USER_ID=123456789

SYMBOL_WHITELIST=SOL,BNB,BTC,ETH
DEFAULT_MARGIN_PER_TRADE=25
DEFAULT_MAX_LEVERAGE_CAP=20
DEFAULT_PROFIT_PARTIAL_CLOSE_PERCENT=25
DRY_RUN=true
PAUSED=false

VALIANT_EXECUTION_MODE=dry-run
VALIANT_BASE_URL=https://app.valiant.trade
VALIANT_AGENT_KEY=
VALIANT_PRIVATE_API_BASE_URL=
VALIANT_PRIVATE_API_KEY=
VALIANT_PRIVATE_API_SECRET=
VALIANT_PLAYWRIGHT_PROFILE_DIR=./playwright-profile
VALIANT_MARKET_ROUTE=/perps
